# Required (default configured for Cerebras)
CEREBRAS_API_KEY=

# Gmail Agent
# GOOGLE_CREDENTIALS_PATH=/path/to/credentials.json

# Postgres (defaults in compose match db/url.py if unset)
# DB_USER=your_postgres_user
# DB_PASS=your_postgres_password
# DB_DATABASE=your_database_name

# Scheduler (set in production to point to your AgentOS URL)
# AGENTOS_URL=https://your-agentos-url.com
